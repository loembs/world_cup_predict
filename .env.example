# ============================================================
# Configuration Supabase - World Cup App Frontend
# ============================================================
# Copie ce fichier en .env et remplace les valeurs par tes clés

# URL de ton projet Supabase
VITE_SUPABASE_URL=https://xafwxhhsoewaelnzhwqe.supabase.co

# Clé publique (anon) - pour les requêtes depuis le frontend
# Récupère-la depuis: https://supabase.com/dashboard/project/xafwxhhsoewaelnzhwqe/settings/api
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel: Forcer le mode de prédiction
# - auto: utilise Supabase, fallback sur local si indisponible
# - supabase: utilise uniquement Supabase (erreur si indisponible)
# - local: utilise uniquement le calcul local
VITE_PREDICTION_MODE=auto
